# EAS AI Dashboard — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================================
# Supabase Configuration
# ============================================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# AI Services (Phase 8 & Beyond)
# ============================================================

# OpenAI API for Phase 8 (suggestions & validation)
# Get your key: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-proj-...

# Anthropic Claude API for adoption agent
# Get your key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# Backend Server (Node.js)
# ============================================================

PORT=3001
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# ============================================================
# NOTE: Backend starts with: cd server && npm install && npm start
# Frontend: http://localhost (served via GitHub Pages or local dev server)
# ============================================================
